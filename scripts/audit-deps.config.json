{
  "$schema": "./audit-deps.config.schema.json",
  "vulnerabilities": {
    "auditLevel": "moderate",
    "scope": "prod"
  },
  "outdated": {
    "blockOn": "major",
    "exceptions": [
      {
        "name": "eslint",
        "latestMajor": 10,
        "reason": "eslint-plugin-react@7.37.5, eslint-plugin-react-hooks@7.0.1, eslint-plugin-jsx-a11y@6.10.2 only peer-dep eslint ^9; runtime confirmed broken on eslint 10",
        "trackingUrl": "https://github.com/jsx-eslint/eslint-plugin-react/issues"
      },
      {
        "name": "@eslint/js",
        "latestMajor": 10,
        "reason": "tied to eslint major; cannot upgrade without bumping eslint, which is blocked by the React plugin ecosystem",
        "trackingUrl": "https://github.com/jsx-eslint/eslint-plugin-react/issues"
      }
    ]
  },
  "licenses": {
    "allow": [
      "0BSD",
      "Apache-2.0",
      "BlueOak-1.0.0",
      "BSD-2-Clause",
      "BSD-3-Clause",
      "CC-BY-3.0",
      "CC-BY-4.0",
      "CC0-1.0",
      "CDDL-1.0",
      "CDDL-1.1",
      "EPL-1.0",
      "EPL-2.0",
      "ISC",
      "MIT",
      "MIT-0",
      "MPL-2.0",
      "Python-2.0",
      "Unlicense",
      "WTFPL"
    ],
    "block": [
      "AGPL-1.0",
      "AGPL-3.0",
      "GPL-1.0",
      "GPL-2.0",
      "GPL-3.0",
      "LGPL-2.0",
      "LGPL-2.1",
      "LGPL-3.0",
      "SSPL-1.0"
    ],
    "review": ["UNKNOWN"],
    "exceptions": []
  }
}
