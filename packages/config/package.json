{
  "name": "@cad/config",
  "version": "0.0.1",
  "private": true,
  "description": "Shared build, lint, format, and test presets for the CAD monorepo.",
  "type": "module",
  "exports": {
    "./eslint": {
      "types": "./dist/eslint.d.ts",
      "default": "./dist/eslint.js"
    },
    "./prettier": {
      "types": "./dist/prettier.d.ts",
      "default": "./dist/prettier.js"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "default": "./dist/vitest.js"
    },
    "./tsconfig/base": "./tsconfig.base.json",
    "./tsconfig/lib": "./tsconfig.lib.json",
    "./tsconfig/node": "./tsconfig.node.json",
    "./tsconfig/browser": "./tsconfig.browser.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "tsconfig.base.json",
    "tsconfig.lib.json",
    "tsconfig.node.json",
    "tsconfig.browser.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests in @cad/config' && exit 0",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/eslint-plugin": "^1.6.15",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  }
}
