{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@cad/config/tsconfig/lib",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["test/**/*", "**/*.test.ts", "**/*.int.test.ts"]
}
