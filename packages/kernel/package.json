{
  "name": "@cad/kernel",
  "version": "0.0.1",
  "private": true,
  "description": "Industrial B-rep geometry kernel (replicad + OpenCascade.js WASM) for the CAD monorepo.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "tsx scripts/gen-version.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ."
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "replicad": "^0.23.0",
    "replicad-opencascadejs": "^0.23.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cad/config": "workspace:*",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
