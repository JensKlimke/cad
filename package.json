{
  "name": "cad",
  "version": "0.0.1",
  "private": true,
  "description": "AI-ready parametric CAD system",
  "type": "module",
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/patch-occt-esm.mjs && pnpm --filter @cad/config build",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm lint:code && pnpm lint:handbook",
    "lint:code": "eslint .",
    "lint:handbook": "tsx scripts/lint-handbook.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "i18n:extract": "i18next-cli extract",
    "i18n:check": "i18next-cli extract --dry-run --ci",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:api": "pnpm --filter @cad/tests-api test",
    "test:e2e": "pnpm --filter @cad/tests-e2e test",
    "audit": "tsx scripts/audit-deps.ts",
    "audit:deps": "tsx scripts/audit-deps.ts",
    "audit:vulns": "tsx scripts/audit-deps.ts --only=vulns",
    "audit:unused": "tsx scripts/audit-deps.ts --only=unused",
    "audit:outdated": "tsx scripts/audit-deps.ts --only=outdated",
    "audit:licenses": "tsx scripts/audit-deps.ts --only=licenses",
    "test:mutation": "stryker run tests/mutation/stryker.conf.json",
    "clean": "turbo run clean && rimraf node_modules",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "@cad/config": "workspace:*",
    "@eslint/js": "^9.39.4",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "i18next-cli": "^1.56.7",
    "knip": "^6.7.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
