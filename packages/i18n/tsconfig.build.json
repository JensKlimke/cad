{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@cad/config/tsconfig/lib",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "lib": ["ES2023", "DOM"]
  },
  "include": ["src/**/*"],
  "exclude": ["test/**/*", "**/*.test.ts", "**/*.test.tsx"]
}
