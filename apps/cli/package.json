{
  "name": "@cad/cli",
  "version": "0.0.1",
  "private": true,
  "description": "`cad` command-line interface for the CAD monorepo.",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "cad": "./bin/cad.js"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "tsx scripts/gen-version.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ."
  },
  "dependencies": {
    "@cad/kernel": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@cad/config": "workspace:*",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
